<UserControl x:Class="LoginWpf.UserControls.LoginInput"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LoginWpf.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="200">
    <Grid>
        <TextBlock x:Name="tbPlaceHolder" FontSize="16"
            VerticalAlignment="Center" 
            Foreground="WhiteSmoke"
            Margin="5,0,0,0"/>
        <TextBox x:Name="txtInput" 
            Background="Transparent" 
            FontSize="16"
            BorderThickness="0"
            VerticalAlignment="Center" TextChanged="txtInput_TextChanged" />
        <Button 
            x:Name="btnClear"
            Content="X"  
            FontSize="16" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Right"
            Foreground="LightGray"
            BorderThickness="0"
            Background="Transparent"          
            Margin="0,0,5,0" Click="btnClear_Click" />
    </Grid>
</UserControl>
